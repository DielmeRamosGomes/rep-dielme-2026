algoritmo "ContagemComBug"
var
   contador: inteiro
inicio
   contador <- 5
   enquanto contador > 0 faca
      escreval("Contando...", contador)
      escreval("DEBUG: O valor do contador é:", contador, ". A condição (contador > 0) é verdadeira.")
   fimenquanto
   escreval("Lançar!")
fimalgoritmo
